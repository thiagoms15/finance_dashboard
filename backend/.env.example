ENV=development
HTTP_ADDR=:8080
METRICS_ADDR=
DATABASE_URL=postgres://finance_app:finance_app@localhost:5432/finance?sslmode=disable
MIGRATIONS_DATABASE_URL=postgres://finance_migrate:finance_migrate@localhost:5432/finance?sslmode=disable
JWT_SECRET=replace-with-at-least-32-characters
JWT_ISSUER=finance-backend
JWT_AUDIENCE=finance-frontend
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/auth
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SAME_SITE=Lax
REFRESH_COOKIE_SECURE=false
ARGON2_TIME=1
ARGON2_MEMORY=65536
ARGON2_THREADS=4
ARGON2_KEY_LEN=32
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
BRAPI_TOKEN=
FINNHUB_KEY=
COINGECKO_KEY=
FX_PROVIDER_KEY=
CORS_ORIGINS=http://localhost:5173
